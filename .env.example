# Supabase bağlantı bilgileri
# Supabase Dashboard > Project Settings > API Keys bölümünden alınır.
# Gerçek değerleri .env.local dosyasına koyun (bu dosya git'e gitmez).

# Proje URL'i
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable key (eski "anon" key) — tarayıcıya açık olabilir, public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Secret key (eski "service_role" key) — YALNIZCA sunucu, ASLA tarayıcıya gitmez
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx
