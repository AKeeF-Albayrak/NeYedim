# Supabase bağlantı bilgileri
# Supabase Dashboard > Project Settings > API bölümünden alınır.
# Gerçek değerleri .env.local dosyasına koyun (bu dosya git'e gitmez).

# Tarayıcıya açık olabilen değerler (public)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Yalnızca sunucu tarafında kullanılır — ASLA tarayıcıya gönderilmez
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
